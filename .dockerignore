# Exclude git repository metadata
.git
.gitignore
.dockerignore

# Exclude sensitive notes and personal data
notes/
my-local-notes/
data/
.recycle_bin/
.dataDir/
backend/data/
backend/tmp/

# Exclude dependencies and build outputs
**/node_modules/
**/out/
**/.next/
frontend/.next/
frontend/out/
frontend/node_modules/
backend/simple-data-flow
backend/tmp/

# Exclude local configuration and environment files
.env
.env.*
*.local

# Exclude IDE/editor configurations
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Exclude build and publish scripts
publish.sh
build.sh
